# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=pe_intelligence

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI (LLM extraction fallback)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (LLM extraction, default provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# LLM provider for extraction: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Exa (semantic web search)
EXA_API_KEY=your-exa-api-key

# SEC EDGAR
SEC_EDGAR_USER_AGENT=YourCompany admin@yourcompany.com

# Application
PORT=3000
NODE_ENV=development

# Extraction
EXTRACTION_CONFIDENCE_THRESHOLD=0.5

# Pipeline automation
PIPELINE_AUTO_CHAIN=true
PIPELINE_CRON_SCHEDULE=0 0 * * 0
PIPELINE_SEED_TARGET=50
